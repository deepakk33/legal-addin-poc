# Copy to .env (cp .env.example .env), then fill in a key. Gitignored — never commit .env.

# Which model backend: openai (default) | anthropic | ollama
MODEL_PROVIDER=openai

# --- OpenAI (default) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Anthropic / Claude (set MODEL_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MAX_TOKENS=4096

# --- Ollama (local, no key — set MODEL_PROVIDER=ollama) ---
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_TIMEOUT_MS=120000

# --- Server ---
BACKEND_PORT=3001
ADDIN_ORIGIN=https://localhost:3000
# AUDIT_DB_PATH=./db/audit.db
