# Copy to .env (or export these) to override defaults.

# Which model backend to use: ollama (default) | anthropic | openai
MODEL_PROVIDER=ollama

# --- Ollama (local, default) ---
OLLAMA_MODEL=llama3.1:8b
OLLAMA_HOST=http://localhost:11434
OLLAMA_TIMEOUT_MS=120000

# --- Anthropic / Claude (set MODEL_PROVIDER=anthropic) ---
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_MAX_TOKENS=4096

# --- OpenAI (set MODEL_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Server ---
BACKEND_PORT=3001
ADDIN_ORIGIN=https://localhost:3000
# AUDIT_DB_PATH=./db/audit.db
